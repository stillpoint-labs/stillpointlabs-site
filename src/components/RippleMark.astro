---
/**
 * RippleMark — inline SVG of the Stillpoint Labs parent brand mark.
 * A center dot surrounded by three concentric rings. Stillwater stroke.
 * Based on the brand guide spec: "a water drop ripple viewed from above."
 */
interface Props {
  size?: number;
  class?: string;
}

const { size = 56, class: className } = Astro.props;
const r1 = size * 0.107; /* center dot radius ~6px at 56px */
const r2 = size * 0.268; /* inner ring ~15px radius at 56px */
const r3 = size * 0.411; /* middle ring ~23px radius at 56px */
const r4 = size * 0.464; /* outer ring ~26px radius at 56px */
const cx = size / 2;
---

<svg
  width={size}
  height={size}
  viewBox={`0 0 ${size} ${size}`}
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class={className}
>
  <!-- Outer ring — most faded -->
  <circle
    cx={cx}
    cy={cx}
    r={r4}
    stroke="currentColor"
    stroke-width="0.75"
    opacity="0.28"
  />
  <!-- Middle ring -->
  <circle
    cx={cx}
    cy={cx}
    r={r3}
    stroke="currentColor"
    stroke-width="1"
    opacity="0.50"
  />
  <!-- Inner ring -->
  <circle
    cx={cx}
    cy={cx}
    r={r2}
    stroke="currentColor"
    stroke-width="1.25"
    opacity="0.72"
  />
  <!-- Center dot — solid -->
  <circle
    cx={cx}
    cy={cx}
    r={r1}
    fill="currentColor"
  />
</svg>
